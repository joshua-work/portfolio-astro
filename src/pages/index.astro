---
import FilmGrid from '@/components/film/FilmGrid.astro';
import FilmGrain from '@/components/film/FilmGrain.svelte';
import BaseLayout from '@/components/layout/BaseLayout.astro';
import { getFilmSummaries, getHomePage } from '@/lib/content/site';

const [homePage, films] = await Promise.all([getHomePage(), getFilmSummaries()]);
---

<BaseLayout title="Joshua Portfolio">
  <section class="content-shell section-spacing">
    <div class="relative max-w-full overflow-hidden rounded-[2rem] border border-white/10 bg-surface/70 px-6 py-12 md:px-10 md:py-16">
      <div class="relative z-10 max-w-4xl">
        <p class="text-sm uppercase tracking-[0.24em] text-accent">{homePage.eyebrow}</p>
        <h1 class="mt-5 break-words font-display text-5xl leading-none text-primary md:text-7xl lg:text-balance">
          {homePage.title}
        </h1>
        <p class="mt-8 max-w-2xl text-base leading-8 text-secondary md:text-lg">
          {homePage.intro}
        </p>

        <div class="mt-10 flex flex-wrap gap-3">
          {
            homePage.focusAreas.map((area) => (
              <span class="rounded-full border border-white/10 bg-background/40 px-4 py-3 text-xs uppercase tracking-[0.22em] text-secondary">
                {area}
              </span>
            ))
          }
        </div>
      </div>
      <FilmGrain client:visible opacity={0.14} size={0.9} />
    </div>
  </section>

  <FilmGrid films={films} />
</BaseLayout>
