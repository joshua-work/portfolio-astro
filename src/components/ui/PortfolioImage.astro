---
import { Image } from 'astro:assets';

import { buildImageUrl } from '@/lib/sanity/image';
import { imagePresets, type ImagePresetName } from '@/lib/sanity/image-presets';
import type { SanityImage } from '@/lib/sanity/types';

type Props = {
  image: SanityImage;
  alt?: string;
  width?: number;
  widths?: number[];
  variant?: ImagePresetName;
  class?: string;
  sizes?: string;
  loading?: 'eager' | 'lazy';
};

const {
  image,
  alt,
  width,
  widths,
  variant,
  class: className = '',
  sizes,
  loading = 'lazy',
} = Astro.props;

const preset = variant ? imagePresets[variant] : undefined;
const resolvedAlt = alt ?? image.alt ?? '';
const resolvedWidth = width ?? preset?.width;

if (!resolvedWidth) {
  throw new Error('PortfolioImage requires either a width or a variant.');
}

const sourceWidth = image.asset.metadata.dimensions.width;
const sourceHeight = image.asset.metadata.dimensions.height;
const height = Math.round(resolvedWidth * (sourceHeight / sourceWidth));
const candidateWidths = (widths ?? preset?.widths)?.filter((candidateWidth) => candidateWidth <= sourceWidth);
const resolvedWidths =
  candidateWidths && candidateWidths.length > 0
    ? Array.from(new Set([...candidateWidths, resolvedWidth])).sort((left, right) => left - right)
    : undefined;
const resolvedSizes = sizes ?? preset?.sizes;
---

<Image
  src={buildImageUrl(image, { width: resolvedWidth })}
  alt={resolvedAlt}
  width={resolvedWidth}
  height={height}
  widths={resolvedWidths}
  sizes={resolvedSizes}
  loading={loading}
  class={className}
  format="webp"
/>
