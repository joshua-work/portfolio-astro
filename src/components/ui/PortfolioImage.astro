---
import { resolveImageSource } from '@/lib/sanity/image';
import { imagePresets, type ImagePresetName } from '@/lib/sanity/image-presets';
import type { SanityImage } from '@/lib/sanity/types';

type Props = {
  image: SanityImage;
  alt?: string;
  width?: number;
  widths?: number[];
  variant?: ImagePresetName;
  class?: string;
  sizes?: string;
  loading?: 'eager' | 'lazy';
  fetchpriority?: 'high' | 'low' | 'auto';
};

const {
  image,
  alt,
  width,
  widths,
  variant,
  class: className = '',
  sizes,
  loading = 'lazy',
  fetchpriority = 'auto',
} = Astro.props;

const preset = variant ? imagePresets[variant] : undefined;
const resolvedAlt = alt ?? image.alt ?? '';
const resolvedWidth = width ?? preset?.width;

if (!resolvedWidth) {
  throw new Error('PortfolioImage requires either a width or a variant.');
}

const source = resolveImageSource(image, {
  width: resolvedWidth,
  widths: widths ?? preset?.widths,
  sizes: sizes ?? preset?.sizes,
});

const aspectRatio = source.width / source.height;
const displayHeight = Math.round(resolvedWidth / aspectRatio);

const lqipStyle = source.lqip 
  ? `background-image: url("${source.lqip}"); background-size: cover; background-position: center;` 
  : '';
---

<img
  src={source.src}
  srcset={source.srcSet}
  sizes={source.sizes}
  alt={resolvedAlt}
  width={resolvedWidth}
  height={displayHeight}
  loading={loading}
  fetchpriority={fetchpriority}
  decoding="async"
  class:list={[className, "bg-surface/50 transition-all duration-[var(--duration-slow)] ease-[var(--easing-film)]"]}
  style={lqipStyle}
/>
