---
import type { NavItem, SiteSettings } from '@/lib/sanity/types';

type Props = {
  settings: Pick<SiteSettings, 'logo' | 'primaryNav' | 'siteTitle'>;
  currentPath?: string;
};

const { settings, currentPath = '/' } = Astro.props;
const links: NavItem[] = settings.primaryNav;
---

<header class="sticky top-0 z-20 border-b border-white/10 bg-background/90 backdrop-blur-md">
  <div class="content-shell flex min-h-16 items-center justify-between gap-6 py-3">
    <a href="/" class="focus-ring inline-flex min-h-11 items-center font-display text-2xl tracking-[0.08em] text-primary">
      {settings.siteTitle}
    </a>

    <nav aria-label="Primary navigation">
      <ul class="flex items-center gap-2 md:gap-4">
        {
          links.map((link) => (
            <li>
              <a
                href={link.href}
                aria-current={currentPath === link.href ? 'page' : undefined}
                class:list={[
                  'focus-ring inline-flex min-h-11 items-center rounded-full px-4 text-sm uppercase tracking-[0.22em] transition-colors duration-300 ease-[var(--easing-film)]',
                  currentPath === link.href
                    ? 'bg-white/6 text-accent'
                    : 'text-secondary hover:text-accent',
                ]}
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>
